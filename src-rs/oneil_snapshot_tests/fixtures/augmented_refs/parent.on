# Parent model that uses a child and applies a design with augmented params

use child as c
use design augment for c

# Reference existing parameter from child (syntax is param.ref)
From child: x = base.c

# Reference design-augmented parameters
Doubled from design: y = doubled.c
Constant from design: z = constant.c

# Compute using augmented param
Sum: total = base.c + doubled.c + constant.c
